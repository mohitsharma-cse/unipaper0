PORT=5000
NODE_ENV=development
API_PUBLIC_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/unipaper

JWT_SECRET=replace_this_with_a_long_random_secret_32_chars_minimum
JWT_EXPIRES_IN=24h

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@unipaper.local
ADMIN_PASSWORD=change-this-password

# Storage provider:
# auto = use UploadThing if configured, else Cloudinary if configured, else local uploads.
# uploadthing = require UploadThing token.
# cloudinary = require Cloudinary values.
# local = store PDFs in backend/uploads/pdfs for development.
STORAGE_PROVIDER=auto

# UploadThing PDF storage.
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
UPLOADTHING_STORAGE_KEY=uploadthing-1
UPLOADTHING_STORAGE_LABEL=UploadThing 1
UPLOADTHING_2_KEY=uploadthing-2
UPLOADTHING_2_LABEL=UploadThing 2
UPLOADTHING_2_TOKEN=
UPLOADTHING_2_APP_ID=

# Legacy Cloudinary fallback for old files only. It is not shown in admin upload choices.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_STORAGE_LABEL=Cloudinary

# Optional: expose local server storage as an admin dropdown option in development.
# ENABLE_LOCAL_STORAGE_OPTION=true
