PORT=5000
NODE_ENV=development
API_PUBLIC_URL=http://localhost:5000
# Comma-separated frontend URLs allowed by CORS.
CLIENT_URL=http://localhost:3000,https://justudynotes-bgapgdajejggdrbj.eastasia-01.azurewebsites.net

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/unipaper

JWT_SECRET=replace_this_with_a_long_random_secret_32_chars_minimum
JWT_EXPIRES_IN=24h
COOKIE_SAME_SITE=none
# Set to true in production (Azure uses HTTPS automatically)
COOKIE_SECURE=false

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@unipaper.local
ADMIN_PASSWORD=change-this-password

# Storage provider:
# auto = use UploadThing if configured, else local uploads.
# uploadthing = require at least one UploadThing token for new uploads.
# local = store PDFs in backend/uploads/pdfs for development.
# Cloudinary is kept only to read old Cloudinary files, not for new admin uploads.
STORAGE_PROVIDER=uploadthing

# UploadThing PDF storage.
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
UPLOADTHING_STORAGE_KEY=uploadthing-1
UPLOADTHING_STORAGE_LABEL=UploadThing 1
UPLOADTHING_2_KEY=uploadthing-2
UPLOADTHING_2_LABEL=UploadThing 2
UPLOADTHING_2_TOKEN=
UPLOADTHING_2_APP_ID=

# Legacy Cloudinary fallback for old files only. It is not shown in admin upload choices.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_STORAGE_LABEL=Cloudinary

# Optional: expose local server storage as an admin dropdown option in development.
# ENABLE_LOCAL_STORAGE_OPTION=true
