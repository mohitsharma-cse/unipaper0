# Set these in Azure Portal > App Service > Environment variables.
# Keep real secret values out of GitHub.

NODE_ENV=production
WEBSITE_NODE_DEFAULT_VERSION=~22

# Use this only if you deploy source without node_modules and want Azure/Kudu to install dependencies.
# The current GitHub Actions workflow already installs and uploads production dependencies.
# SCM_DO_BUILD_DURING_DEPLOYMENT=true

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/unipaper
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=24h

CLIENT_URL=https://your-app.azurewebsites.net
API_PUBLIC_URL=https://your-app.azurewebsites.net
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true

STORAGE_PROVIDER=uploadthing
UPLOADTHING_TOKEN=replace_with_uploadthing_token
UPLOADTHING_APP_ID=replace_with_uploadthing_app_id
UPLOADTHING_STORAGE_KEY=uploadthing-1
UPLOADTHING_STORAGE_LABEL=UploadThing 1

# Optional second UploadThing storage destination.
UPLOADTHING_2_TOKEN=
UPLOADTHING_2_APP_ID=
UPLOADTHING_2_KEY=uploadthing-2
UPLOADTHING_2_LABEL=UploadThing 2

# Used by seed scripts when creating the first admin.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@unipaper.local
ADMIN_PASSWORD=replace_with_strong_admin_password
